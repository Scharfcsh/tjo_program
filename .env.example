# --- Database ---------------------------------------------------------------
# MongoDB connection string (e.g. a free MongoDB Atlas cluster).
MONGODB_URI=

# --- Auth / sessions --------------------------------------------------------
# Long random string used to sign session + magic-link tokens (jose HS256).
# Generate one with: openssl rand -base64 32
SESSION_SECRET=
# Shared password for the /admin area.
ADMIN_PASSWORD=

# --- Email (nodemailer over SMTP) -------------------------------------------
# Leave SMTP_* unset to log emails to the server console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TopJobOffer Ambassadors <ambassadors@topjoboffer.com>"

# --- App --------------------------------------------------------------------
# Public base URL of the intern portal, used to build magic links in emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Invite link for the official ambassador WhatsApp group (dashboard join task).
NEXT_PUBLIC_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/
# Official social pages students follow during onboarding.
NEXT_PUBLIC_TJO_LINKEDIN_URL=https://www.linkedin.com/company/top-job-offer/
NEXT_PUBLIC_TJO_TWITTER_URL=https://x.com/topjoboffer
NEXT_PUBLIC_TJO_INSTAGRAM_URL=https://www.instagram.com/topjoboffer/

# --- Main-app verification API ----------------------------------------------
# mock = use built-in fixtures (default). live = call the real endpoint below.
TJO_API_MODE=mock
# Base URL of the main app's API; the client appends /ambassadors/... paths.
TJO_API_BASE_URL=https://topjoboffer.com/api
# Shared secret sent as the `x-api-key` header on every request.
AMBASSADOR_API_KEY="amb-k39gn3wcKFmk2ewKFEK23"
